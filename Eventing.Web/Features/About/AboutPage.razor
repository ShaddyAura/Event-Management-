@page "/about"
@using Eventing.Web.Components.Layout
@layout MainLayout

<!-- Hero -->
<section class="pg-hero pg-hero-about">
    <div class="pg-hero-content">
        <span class="pg-hero-tag">Our Story</span>
        <h1>About <span class="mx-accent">MeetupX</span></h1>
        <p>We believe great things happen when curious people get together. MeetupX is the platform that makes that happen — online and in the real world.</p>
    </div>
</section>

<!-- Mission -->
<section class="ab-section ab-mission">
    <div class="ab-split">
        <div class="ab-split-text">
            <h2>Our <span class="mx-underline">Mission</span></h2>
            <p>
                MeetupX exists to break down the barriers between people who share passions,
                ideas, and ambitions. Whether you're a developer, marketer, startup founder,
                or student — there's a community waiting for you.
            </p>
            <p>
                We build tools that make it effortless to discover events, connect with speakers,
                and share knowledge with a global audience.
            </p>
            <div class="ab-highlights">
                <div class="ab-highlight-item">
                    <span class="ab-highlight-icon">🚀</span>
                    <div>
                        <strong>Founded in 2024</strong>
                        <span>Born from a passion for community</span>
                    </div>
                </div>
                <div class="ab-highlight-item">
                    <span class="ab-highlight-icon">🌍</span>
                    <div>
                        <strong>Global Reach</strong>
                        <span>Events across 40+ countries</span>
                    </div>
                </div>
                <div class="ab-highlight-item">
                    <span class="ab-highlight-icon">🤝</span>
                    <div>
                        <strong>Community First</strong>
                        <span>Always free to discover and attend</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="ab-split-visual">
            <div class="ab-visual-card">
                <div class="ab-vc-stat">
                    <span class="ab-vc-num">5,000<span class="mx-accent">+</span></span>
                    <span>Attendees</span>
                </div>
                <div class="ab-vc-divider"></div>
                <div class="ab-vc-stat">
                    <span class="ab-vc-num">200<span class="mx-accent">+</span></span>
                    <span>Events</span>
                </div>
                <div class="ab-vc-divider"></div>
                <div class="ab-vc-stat">
                    <span class="ab-vc-num">40<span class="mx-accent">+</span></span>
                    <span>Countries</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="ab-section ab-values">
    <div class="ab-section-header">
        <h2>What We <span class="mx-underline">Stand For</span></h2>
        <p>Our values guide every decision we make.</p>
    </div>
    <div class="ab-values-grid">
        <div class="ab-value-card">
            <div class="ab-value-icon" style="background:#e91e63;">🔓</div>
            <h3>Openness</h3>
            <p>Knowledge should be accessible to everyone, regardless of background or location.</p>
        </div>
        <div class="ab-value-card">
            <div class="ab-value-icon" style="background:#7c3aed;">💡</div>
            <h3>Innovation</h3>
            <p>We constantly push the boundaries of what a community platform can be.</p>
        </div>
        <div class="ab-value-card">
            <div class="ab-value-icon" style="background:#2563eb;">🤝</div>
            <h3>Collaboration</h3>
            <p>The best ideas emerge when diverse minds work together toward a common goal.</p>
        </div>
        <div class="ab-value-card">
            <div class="ab-value-icon" style="background:#059669;">🌱</div>
            <h3>Growth</h3>
            <p>Every event is an opportunity to learn something new and become a better version of yourself.</p>
        </div>
    </div>
</section>

<!-- Team -->
<section class="ab-section ab-team">
    <div class="ab-section-header">
        <h2>Meet the <span class="mx-underline">Team</span></h2>
        <p>The passionate people behind MeetupX.</p>
    </div>
    <div class="ab-team-grid">
        <div class="ab-team-card">
            <div class="ab-team-avatar" style="background:linear-gradient(135deg,#e91e63,#7c3aed)">AS</div>
            <h4>Alex Singh</h4>
            <span class="ab-team-role">Founder & CEO</span>
            <p>Passionate about community building and open knowledge sharing.</p>
        </div>
        <div class="ab-team-card">
            <div class="ab-team-avatar" style="background:linear-gradient(135deg,#7c3aed,#2563eb)">MR</div>
            <h4>Maya Rivera</h4>
            <span class="ab-team-role">Head of Product</span>
            <p>Designing experiences that bring thousands of people together.</p>
        </div>
        <div class="ab-team-card">
            <div class="ab-team-avatar" style="background:linear-gradient(135deg,#2563eb,#059669)">JK</div>
            <h4>James Kim</h4>
            <span class="ab-team-role">Lead Engineer</span>
            <p>Building the infrastructure that powers every MeetupX event.</p>
        </div>
        <div class="ab-team-card">
            <div class="ab-team-avatar" style="background:linear-gradient(135deg,#059669,#e91e63)">SP</div>
            <h4>Sara Patel</h4>
            <span class="ab-team-role">Community Manager</span>
            <p>Making sure every member feels welcome and inspired.</p>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="ab-cta">
    <h2>Ready to join the community?</h2>
    <p>Create your account and start discovering events today.</p>
    <div class="ab-cta-actions">
        <a href="/register" class="mx-btn-primary">Get Started Free</a>
        <a href="/events" class="mx-btn-outline">Browse Events</a>
    </div>
</section>
