@page "/login"
@rendermode InteractiveServer
@using Eventing.Web.Components.Layout
@layout MainLayout

<div class="auth-page">
    <!-- Left Panel -->
    <div class="auth-left">
        <span class="auth-date-badge">12-14 February 2025 · Los Angeles, CA</span>
        <h1>Welcome<br />Back to<br /><span class="mx-accent">MeetupX</span></h1>
        <p class="auth-sub">Sign in to access your tickets, manage your profile, and stay updated on the latest events.</p>

        <div class="auth-features">
            <div class="auth-feature-item">
                <div class="auth-feature-icon" style="background:#e91e63;">👥</div>
                <div>
                    <strong>Connect</strong>
                    <p>Network with innovators and industry leaders.</p>
                </div>
            </div>
            <div class="auth-feature-item">
                <div class="auth-feature-icon" style="background:#7c3aed;">📚</div>
                <div>
                    <strong>Learn</strong>
                    <p>Access talks, workshops, and exclusive content.</p>
                </div>
            </div>
            <div class="auth-feature-item">
                <div class="auth-feature-icon" style="background:#059669;">🔔</div>
                <div>
                    <strong>Stay Updated</strong>
                    <p>Be the first to know about events and offers.</p>
                </div>
            </div>
        </div>

        <div class="auth-left-footer">
            <p>Don't have an account? <a href="/register" class="auth-link">Create one</a></p>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="auth-right">
        <div class="auth-card">
            <h2>Sign In</h2>
            <p class="auth-card-sub">Welcome back! Enter your credentials to continue.</p>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="auth-error">@_errorMessage</div>
            }

            <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="Login">
                <DataAnnotationsValidator />

                <div class="auth-form-group">
                    <label>Email Address</label>
                    <InputText @bind-Value="_model.Email" class="auth-input" placeholder="Enter your email address" type="email" />
                    <ValidationMessage For="@(() => _model.Email)" class="auth-validation" />
                </div>

                <div class="auth-form-group">
                    <label>Password</label>
                    <div class="auth-input-wrap">
                        <InputText @bind-Value="_model.Password" class="auth-input" placeholder="Enter your password"
                                   type="@(_showPassword ? "text" : "password")" />
                        <button type="button" class="auth-eye" @onclick="TogglePassword">
                            @(_showPassword ? "🙈" : "👁")
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _model.Password)" class="auth-validation" />
                </div>

                <div class="auth-row">
                    <label class="auth-remember">
                        <InputCheckbox @bind-Value="_model.RememberMe" />
                        <span>Remember me</span>
                    </label>
                    <a href="#" class="auth-link auth-forgot">Forgot password?</a>
                </div>

                <button type="submit" class="auth-submit" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span>Signing in…</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>
            </EditForm>

            <p class="auth-switch">
                Don't have an account? <a href="/register" class="auth-link">Create Account</a>
            </p>
        </div>
    </div>
</div>
